# Azure DevOps Configuration
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/sda-iatec
AZURE_DEVOPS_PAT=seu-personal-access-token-aqui
AZURE_DEVOPS_PROJECT=nome-do-projeto

# Git Configuration
GIT_USER_NAME=seu-nome
GIT_USER_EMAIL=seu-email@sda-iatec.com

# Workspace Configuration
WORKSPACE_ROOT=/caminho/para/workspace
SOLUTION_PATH=/caminho/para/solution.sln

# Test Configuration
TEST_TIMEOUT_MS=120000
E2E_BASE_URL=http://localhost:5000

# Build Configuration  
DOTNET_SDK_VERSION=8.0
BUILD_CONFIGURATION=Debug

# Documentation Repository (docs-dracma)
DOCS_REPO_NAME=docs-dracma
DOCS_REPO_URL=https://dev.azure.com/sda-iatec/projeto/_git/docs-dracma
DOCS_BASE_PATH=docs/features
DOCS_TARGET_BRANCH=main
